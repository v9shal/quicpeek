{
  "name": "monihel",
  "version": "1.0.0",
  "description": "API and workers for endpoint monitoring and alerting system.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch 'api/src/**/*.ts' --exec 'ts-node' api/src/index.ts",
    "dev:worker:ping": "nodemon --watch 'workers/ping/**/*.ts' --exec 'ts-node' workers/ping/index.ts",
    "dev:worker:db": "nodemon --watch 'workers/dbWrite/**/*.ts' --exec 'ts-node' workers/dbWrite/index.ts",
    "build": "tsc",
    "start": "node dist/api/src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
