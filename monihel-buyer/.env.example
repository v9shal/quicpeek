# ── Required ──────────────────────────────────────────────────────────────────
# Your license key from the purchase email
LICENSE_KEY=MNHL-XXXX-XXXX-XXXX

# Strong random passwords — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme

# Encryption key — generate with: openssl rand -hex 32
ENCRYPTION_KEY=changeme

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Free option: sign up at resend.com, get API key, use below settings
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=alerts@yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Your frontend URL (for CORS + email links)
CLIENT_URL=http://localhost:4000

# Port to expose the API on (default: 4000)
PORT=4000
